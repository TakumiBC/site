---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const rawPosts = await getCollection('post');

function normalizeUrl(url) {
  return '/' + String(url || '').replace(/^\/+|\/+$/g, '') + '/';
}

function getPostUrl(post) {
  return normalizeUrl(post.data.permalink || `/post/${post.slug}/`);
}


const posts = rawPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => ({
    title: post.data.title || '',
    description: post.data.description || '',
    dateFormatted: post.data.dateFormatted || post.data.date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    }),
    link: getPostUrl(post),
    body: post.body || '',
    content: post.body || '',
    tags: Array.isArray(post.data.tags) ? post.data.tags.join('|') : (post.data.tags || '')
  }));

function escapeHtml(value) {
  return String(value ?? '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

function renderPostCards(count, template) {
  return posts.slice(0, count).map((post) => {
    let html = template;

    for (const [key, value] of Object.entries(post)) {
      html = html.replaceAll(`{post.${key}}`, escapeHtml(value));
    }

    return html;
  }).join('\n');
}
